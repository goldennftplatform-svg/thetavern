{
  "name": "thetavern",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "media:scan": "node scripts/media-scan.mjs",
    "x:sync": "node scripts/sync-x-lore.mjs",
    "prebuild": "npm run media:scan && npm run x:sync",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "live": "concurrently -n srv,web -c blue,green \"npm run server\" \"vite --host\"",
    "smoke": "node scripts/smoke-play.mjs",
    "smoke:warrior": "node scripts/smoke-warrior.mjs",
    "smoke:bigboard": "node scripts/smoke-bigboard.mjs",
    "smoke:all": "node scripts/smoke-all.mjs",
    "ardy:bake": "node scripts/run-ardy-bake.mjs",
    "ardy:demo": "node scripts/run-ardy-demo.mjs",
    "poles:render": "node scripts/run-blender-poles.mjs",
    "music:fetch": "node scripts/fetch-suno-track.mjs",
    "dashboard": "node scripts/print-dashboard-url.mjs && concurrently -n srv,web -c blue,green \"npm run server\" \"vite --host\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "concurrently": "^9.0.1",
    "image-size": "^2.0.2",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
