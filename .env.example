# Trail server (local). Vercel/static clients use VITE_TRAIL_SERVER_URL at build time instead.
TRAIL_PORT=3847
TRAIL_CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174

# Optional — X lore sync (npm run x:sync). Only needed if syndication returns 429.
# Copy auth_token + ct0 from x.com cookies while logged in:
# X_SYNDICATION_COOKIE=auth_token=...; ct0=...
# X_LORE_HANDLES=DemplarOfficial
